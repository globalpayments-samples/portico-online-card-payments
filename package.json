{
  "name": "card-payments",
  "version": "1.0.0",
  "description": "E2E tests for Global Payments SDK implementations",
  "type": "commonjs",
  "scripts": {
    "test": "playwright test",
    "test:ci": "playwright test --reporter=junit",
    "test:headed": "playwright test --headed", 
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    
    "test:nodejs": "IMPLEMENTATION_FILTER=nodejs playwright test",
    "test:python": "IMPLEMENTATION_FILTER=python playwright test",
    "test:php": "IMPLEMENTATION_FILTER=php playwright test", 
    "test:java": "IMPLEMENTATION_FILTER=java playwright test",
    "test:go": "IMPLEMENTATION_FILTER=go playwright test",
    "test:dotnet": "IMPLEMENTATION_FILTER=dotnet playwright test",
    
    "test:single": "playwright test --workers=1",
    "test:verbose": "playwright test --reporter=list",
    
    "setup": "npm ci && npx playwright install chromium",
    "setup:env": "./setup-env.sh",
    "setup:all": "npm run setup:nodejs && npm run setup:php && npm run setup:python && npm run setup:java && npm run setup:go && npm run setup:dotnet",
    "setup:nodejs": "cd nodejs && npm ci",
    "setup:php": "cd php && composer install --no-dev",
    "setup:python": "cd python && python -m venv venv && source venv/bin/activate && pip install -r requirements.txt",
    "setup:java": "cd java && mvn clean install -DskipTests",
    "setup:go": "cd go && go mod download",
    "setup:dotnet": "cd dotnet && dotnet restore",
    
    "serve:report": "npx playwright show-report",
    "cleanup": "rm -rf test-results playwright-report junit.xml",
    "cleanup:ports": "lsof -ti:8000 | xargs kill -9 || true",
    
    "pretest": "npm run cleanup",
    "posttest": "npm run cleanup:ports"
  },
  "keywords": [
    "testing",
    "e2e",
    "payments"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.39.0"
  },
  "dependencies": {
    "node-fetch": "^2.6.9"
  }
}