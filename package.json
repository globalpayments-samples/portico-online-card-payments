{
  "name": "card-payments",
  "version": "1.0.0",
  "description": "E2E tests for Global Payments SDK implementations",
  "type": "commonjs",
"scripts": {
    "test": "playwright test",
    "test:ci": "playwright test --reporter=junit",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:specific": "playwright test --grep",
    "test:nodejs": "IMPLEMENTATION_FILTER=nodejs playwright test",
    "test:php": "IMPLEMENTATION_FILTER=php playwright test",
    "test:python": "IMPLEMENTATION_FILTER=python playwright test",
    "test:java": "IMPLEMENTATION_FILTER=java playwright test",
    "test:go": "IMPLEMENTATION_FILTER=go playwright test",
    "test:all-browsers": "FULL_BROWSER_TESTS=true playwright test",
    "test:coverage": "playwright test --reporter=html",
    "serve:report": "npx playwright show-report",
    "setup:all": "npm run setup:nodejs && npm run setup:php && npm run setup:python && npm run setup:java && npm run setup:go",
    "setup:nodejs": "cd nodejs && npm ci",
    "setup:php": "cd php && composer install",
    "setup:python": "cd python && python -m venv venv && source venv/bin/activate && pip install -r requirements.txt",
    "setup:java": "cd java && mvn dependency:resolve",
    "setup:go": "cd go && go mod download",
    "cleanup": "rm -rf test-results playwright-report",
    "security:scan": "npm audit && echo 'Run: npx audit-ci --config audit-ci.json' for detailed security check",
    "lint:env": "node scripts/validate-env.js"
  },
  "keywords": [
    "testing",
    "e2e",
    "payments"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.39.0"
  },
  "dependencies": {
    "node-fetch": "^2.6.9"
  }
}
